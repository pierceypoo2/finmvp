# Copy to .env.local for development. Set the same keys in Vercel → Project → Settings → Environment Variables.

# --- Clerk (required for sign-in and protected routes) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Plaid (required for bank / debt linking; use sandbox for demos) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
# Optional overrides (defaults: sandbox)
# PLAID_ENV=sandbox
# NEXT_PUBLIC_PLAID_ENV=sandbox

# --- Token encryption (required for any API that stores Plaid tokens) ---
# 64 hex chars (32 bytes). Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# --- Optional ---
# OPENAI_API_KEY=
